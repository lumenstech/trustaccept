{
  "name": "@trustaccept/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "TrustAccept MCP server — thin proxy over /api/v1/approvals. Exposes request_approval, get_approval_status, list_pending_approvals over stdio.",
  "type": "module",
  "main": "dist/apps/mcp-server/src/index.js",
  "bin": {
    "trustaccept-mcp": "dist/apps/mcp-server/src/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/apps/mcp-server/src/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
