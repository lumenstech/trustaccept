// TrustAccept core schema
// PostgreSQL-compatible. Mock auth for now; identities live in the User table.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductModule {
  AI_ACTION_GATE
  ACCESS_ACCEPT
  VULNERABILITY_ACCEPT
  KEV_EXPOSURE_REVIEW
  SECURE_RELEASE_GATE
  DEVICE_ACCEPT
  EVIDENCE_DESK
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  PENDING
  ACCEPTED
  REJECTED
  REMEDIATION_REQUIRED
  EXPIRED
}

enum Decision {
  ACCEPT
  REJECT
  REMEDIATE
}

enum Role {
  OWNER
  ADMIN
  APPROVER
  VIEWER
}

enum AuditEventType {
  RISK_RECORD_CREATED
  RISK_RECORD_UPDATED
  DECISION_ACCEPTED
  DECISION_REJECTED
  DECISION_REMEDIATION_REQUIRED
  EVIDENCE_PACKET_GENERATED
  APPROVAL_PAGE_VIEWED
  LEAD_FORM_SUBMITTED
}

enum LeadFormType {
  BOOK_RISK_REVIEW
  START_PILOT
  REQUEST_EVIDENCE_DESK
  CONTACT
}

enum LeadStatus {
  NEW
  IN_REVIEW
  CONTACTED
  CLOSED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users          User[]
  riskRecords    RiskRecord[]
  auditLogs      AuditLog[]
  evidencePackets EvidencePacket[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  role           Role     @default(VIEWER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())

  ownedRecords   RiskRecord[] @relation("RecordOwner")
  decidedRecords RiskRecord[] @relation("RecordDecider")
  createdRecords RiskRecord[] @relation("RecordCreatedBy")
  updatedRecords RiskRecord[] @relation("RecordUpdatedBy")
  auditLogs      AuditLog[]
}

model RiskRecord {
  id                    String         @id @default(cuid())
  organizationId        String
  organization          Organization   @relation(fields: [organizationId], references: [id])
  module                ProductModule
  title                 String
  description           String         @db.Text
  sourceSystem          String
  sourceType            String
  riskLevel             RiskLevel
  riskScore             Int            @default(50)
  status                RiskStatus     @default(PENDING)

  ownerId               String?
  owner                 User?          @relation("RecordOwner", fields: [ownerId], references: [id])
  ownerLabel            String
  department            String

  dueDate               DateTime?
  expirationDate        DateTime?
  reviewDate            DateTime?

  decision              Decision?
  decisionById          String?
  decisionBy            User?          @relation("RecordDecider", fields: [decisionById], references: [id])
  decisionByLabel       String?
  decisionAt            DateTime?
  decisionNote          String?        @db.Text

  compensatingControls  String         @db.Text
  evidenceSummary       String         @db.Text
  businessJustification String         @db.Text
  technicalContext      String         @db.Text

  frameworkTags         String[]
  sourceReferences      Json

  createdById           String?
  createdBy             User?          @relation("RecordCreatedBy", fields: [createdById], references: [id])
  updatedById           String?
  updatedBy             User?          @relation("RecordUpdatedBy", fields: [updatedById], references: [id])

  evidencePackets       EvidencePacket[]
  auditLogs             AuditLog[]

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, module])
}

/// Append-only by application convention. The service layer must only INSERT.
model AuditLog {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  riskRecordId   String?
  riskRecord     RiskRecord?    @relation(fields: [riskRecordId], references: [id], onDelete: Cascade)
  eventType      AuditEventType
  actorId        String?
  actor          User?          @relation(fields: [actorId], references: [id])
  actorName      String
  previousStatus RiskStatus?
  newStatus      RiskStatus?
  metadata       Json
  createdAt      DateTime       @default(now())

  @@index([organizationId, createdAt])
  @@index([riskRecordId, createdAt])
}

model EvidencePacket {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  riskRecordId   String
  riskRecord     RiskRecord   @relation(fields: [riskRecordId], references: [id], onDelete: Cascade)
  summary        Json
  generatedAt    DateTime     @default(now())

  @@index([organizationId])
  @@index([riskRecordId])
}

model Lead {
  id          String       @id @default(cuid())
  formType    LeadFormType
  name        String
  company     String
  email       String
  phone       String?
  riskArea    String
  urgency     String
  description String       @db.Text
  status      LeadStatus   @default(NEW)
  createdAt   DateTime     @default(now())
}


enum AgentIdentityStatus { TRUSTED UNKNOWN BLOCKED }
enum AgentPolicyDefaultMode { ALLOW REQUIRE_REVIEW BLOCK }
enum AgentActionRiskLevel { LOW MEDIUM HIGH CRITICAL }
enum AgentActionStatus { PENDING_REVIEW APPROVED REJECTED AUTO_APPROVED AUTO_REJECTED EXPIRED }
enum AgentDecisionType { APPROVED REJECTED REQUEST_MORE_INFO }
enum AgentActorType { SYSTEM AGENT REVIEWER MERCHANT_ADMIN }
enum WebhookDeliveryStatus { PENDING DELIVERED FAILED }

model Merchant {
  id         String   @id @default(cuid())
  name       String
  apiKeyHash String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  policies   AgentPolicy[]
  actions    AgentAction[]
  auditEvents AuditEvent[]
}

model AgentIdentity {
  id           String @id @default(cuid())
  agentId      String @unique
  name         String
  status       AgentIdentityStatus @default(UNKNOWN)
  publicKeyPem String?
  keyId        String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AgentPolicy {
  id                       String @id @default(cuid())
  merchantId               String
  merchant                 Merchant @relation(fields:[merchantId], references:[id])
  defaultMode              AgentPolicyDefaultMode @default(REQUIRE_REVIEW)
  autoApproveBelowAmount   Decimal @default(0) @db.Decimal(12,2)
  requireReviewAboveAmount Decimal @default(500) @db.Decimal(12,2)
  blockAboveAmount         Decimal @default(5000) @db.Decimal(12,2)
  allowedActionTypes       Json
  blockedActionTypes       Json
  allowedCategories        Json
  blockedCategories        Json
  allowedAgentIds          Json
  blockUnknownAgents       Boolean @default(true)
  requireTapSignature      Boolean @default(true)
  businessHoursOnly        Boolean @default(false)
  webhookUrl               String?
  webhookSecretHash        String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  @@unique([merchantId])
}

model AgentAction {
  id              String @id @default(cuid())
  merchantId      String
  merchant        Merchant @relation(fields:[merchantId], references:[id])
  agentId         String
  agentName       String
  consumerRef     String
  actionType      String
  amount          Decimal @db.Decimal(12,2)
  currency        String
  category        String
  paymentToken    String?
  description     String?
  metadata        Json
  tapVerification Json
  policyResult    Json
  riskScore       Int
  riskLevel       AgentActionRiskLevel
  status          AgentActionStatus
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  expiresAt       DateTime?
  decisions       AgentDecision[]
  auditEvents     AuditEvent[]
  webhookDeliveries WebhookDelivery[]
}

model AgentDecision {
  id           String @id @default(cuid())
  actionId     String
  action       AgentAction @relation(fields:[actionId], references:[id], onDelete: Cascade)
  decision     AgentDecisionType
  note         String?
  reviewerName String?
  createdAt    DateTime @default(now())
}

model AuditEvent {
  id         String @id @default(cuid())
  actionId   String?
  action     AgentAction? @relation(fields:[actionId], references:[id], onDelete: Cascade)
  merchantId String?
  merchant   Merchant? @relation(fields:[merchantId], references:[id])
  eventType  String
  actorType  AgentActorType
  actorName  String?
  message    String
  data       Json
  createdAt  DateTime @default(now())
}

model Nonce {
  id        String @id @default(cuid())
  nonce     String
  agentId   String
  createdAt DateTime @default(now())
  expiresAt DateTime
  @@unique([nonce, agentId])
}

model WebhookDelivery {
  id           String @id @default(cuid())
  actionId      String
  action        AgentAction @relation(fields:[actionId], references:[id], onDelete: Cascade)
  url           String
  status        WebhookDeliveryStatus
  responseCode  Int?
  responseBody  String?
  attemptCount  Int @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
