# TrustAccept production environment template.
# Copy to your deployment secret store, not to a committed .env file.

NODE_ENV=production
TRUSTACCEPT_STORAGE_BACKEND=prisma
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

TRUSTACCEPT_DISABLE_DEMO_AUTH=1
TRUSTACCEPT_PUBLIC_BASE_URL=https://trustaccept.your-domain.example

UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token
TRUSTACCEPT_REQUIRE_UPSTASH=1
TRUSTACCEPT_SESSION_KEY_PREFIX=trustaccept:session

TRUSTACCEPT_APPROVAL_TOKEN_SECRET=replace-with-32-plus-random-characters
TRUSTACCEPT_APPROVAL_TOKEN_TTL_SECONDS=604800
TRUSTACCEPT_ALLOWED_TOOL_IDS=trustaccept.request_approval.v1

SEQUENCENOW_WEBHOOK_URL=https://sequencenow.example/hooks/trustaccept
SEQUENCENOW_WEBHOOK_SECRET=replace-with-32-plus-random-characters
TRUSTACCEPT_REQUIRE_SEQUENCENOW_WEBHOOK=1

# Prefer injecting this from the platform secret store. Literal "\n" escapes
# are accepted by the app when the platform stores secrets on one line.
TRUSTACCEPT_RECEIPT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional for operator-side verification scripts.
TRUSTACCEPT_VERIFY_TARGET_URL=https://trustaccept.your-domain.example
TRUSTACCEPT_SMOKE_SESSION_TOKEN=
TRUSTACCEPT_SMOKE_CREATE_APPROVAL=0
