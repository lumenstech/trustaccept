// TrustAccept core schema
// PostgreSQL-compatible. Mock auth for now; identities live in the User table.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductModule {
  AI_ACTION_GATE
  ACCESS_ACCEPT
  VULNERABILITY_ACCEPT
  KEV_EXPOSURE_REVIEW
  SECURE_RELEASE_GATE
  DEVICE_ACCEPT
  EVIDENCE_DESK
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  PENDING
  ACCEPTED
  REJECTED
  REMEDIATION_REQUIRED
  EXPIRED
}

enum Decision {
  ACCEPT
  REJECT
  REMEDIATE
}

enum Role {
  OWNER
  ADMIN
  APPROVER
  VIEWER
}

enum AuditEventType {
  RISK_RECORD_CREATED
  RISK_RECORD_UPDATED
  DECISION_ACCEPTED
  DECISION_REJECTED
  DECISION_REMEDIATION_REQUIRED
  EVIDENCE_PACKET_GENERATED
  APPROVAL_PAGE_VIEWED
  LEAD_FORM_SUBMITTED
}

enum LeadFormType {
  BOOK_RISK_REVIEW
  START_PILOT
  REQUEST_EVIDENCE_DESK
  CONTACT
}

enum LeadStatus {
  NEW
  IN_REVIEW
  CONTACTED
  CLOSED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users           User[]
  riskRecords     RiskRecord[]
  auditLogs       AuditLog[]
  evidencePackets EvidencePacket[]
  apiKeys             ApiKey[]
  webhookEndpoints    WebhookEndpoint[]
  // Singular + optional: SlackInstallation.organizationId is @unique
  // (one install per org). Do NOT change to a list.
  slackInstallation   SlackInstallation?
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  role           Role     @default(VIEWER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())

  ownedRecords   RiskRecord[] @relation("RecordOwner")
  decidedRecords RiskRecord[] @relation("RecordDecider")
  createdRecords RiskRecord[] @relation("RecordCreatedBy")
  updatedRecords RiskRecord[] @relation("RecordUpdatedBy")
  auditLogs      AuditLog[]
}

model RiskRecord {
  id                    String         @id @default(cuid())
  organizationId        String
  organization          Organization   @relation(fields: [organizationId], references: [id])
  module                ProductModule
  title                 String
  description           String         @db.Text
  sourceSystem          String
  sourceType            String
  riskLevel             RiskLevel
  riskScore             Int            @default(50)
  status                RiskStatus     @default(PENDING)

  ownerId               String?
  owner                 User?          @relation("RecordOwner", fields: [ownerId], references: [id])
  ownerLabel            String
  department            String

  dueDate               DateTime?
  expirationDate        DateTime?
  reviewDate            DateTime?

  decision              Decision?
  decisionById          String?
  decisionBy            User?          @relation("RecordDecider", fields: [decisionById], references: [id])
  decisionByLabel       String?
  decisionAt            DateTime?
  decisionNote          String?        @db.Text

  compensatingControls  String         @db.Text
  evidenceSummary       String         @db.Text
  businessJustification String         @db.Text
  technicalContext      String         @db.Text

  frameworkTags         String[]
  sourceReferences      Json
  metadata              Json           @default("{}")

  createdById           String?
  createdBy             User?          @relation("RecordCreatedBy", fields: [createdById], references: [id])
  updatedById           String?
  updatedBy             User?          @relation("RecordUpdatedBy", fields: [updatedById], references: [id])

  evidencePackets       EvidencePacket[]
  auditLogs             AuditLog[]

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, module])
}

/// Append-only by application convention. The service layer must only INSERT.
model AuditLog {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  riskRecordId   String?
  riskRecord     RiskRecord?    @relation(fields: [riskRecordId], references: [id], onDelete: Cascade)
  eventType      AuditEventType
  actorId        String?
  actor          User?          @relation(fields: [actorId], references: [id])
  actorName      String
  previousStatus RiskStatus?
  newStatus      RiskStatus?
  metadata       Json
  createdAt      DateTime       @default(now())

  @@index([organizationId, createdAt])
  @@index([riskRecordId, createdAt])
}

model EvidencePacket {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  riskRecordId   String
  riskRecord     RiskRecord   @relation(fields: [riskRecordId], references: [id], onDelete: Cascade)
  summary        Json
  generatedAt    DateTime     @default(now())

  // Phase 2 / EvidenceDesk receipt fields.
  // SHA-256 of canonicalized receipt body (excluding receiptHash + signature).
  receiptHash    String?
  // HMAC-SHA256(receiptHash, TRUSTACCEPT_RECEIPT_SIGNING_SECRET).
  signature      String?
  receiptVersion Int          @default(1)
  // "decision_request_created" | "decision_recorded" | "manual_export"
  trigger        String?
  exportedAt     DateTime?
  // Immutable snapshot of the RiskRecord at receipt time, so the receipt
  // stays verifiable independent of subsequent record mutations.
  recordSnapshot Json?

  @@index([organizationId])
  @@index([riskRecordId])
}

model Lead {
  id          String       @id @default(cuid())
  formType    LeadFormType
  name        String
  company     String
  email       String
  phone       String?
  riskArea    String
  urgency     String
  description String       @db.Text
  status      LeadStatus   @default(NEW)
  createdAt   DateTime     @default(now())
}

// Phase 2 — Agent Action Receipts API + Slack Approval App.
// All six models are additive; nothing else in this schema depends on them.

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  // First 12 chars of the full key, safe to display in the dashboard.
  prefix         String
  // scrypt(fullKey + TRUSTACCEPT_API_KEY_PEPPER). The full key is shown
  // exactly once at creation and never persisted in plaintext.
  keyHash        String
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([prefix])
}

model WebhookEndpoint {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  url            String
  // Generated once at creation, shown once, then masked.
  signingSecret  String
  enabled        Boolean           @default(true)
  description    String?
  createdAt      DateTime          @default(now())

  deliveries     WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id                String          @id @default(cuid())
  webhookEndpointId String
  webhookEndpoint   WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  // Nullable: receipt.created events reference a receipt, not a record.
  // Do NOT tighten this to a non-null relation.
  riskRecordId      String?
  // "decision.created" | "decision.accepted" | "decision.rejected"
  //   | "decision.remediation_required" | "receipt.created"
  eventType         String
  payload           Json
  // HMAC-SHA256 of the canonicalized payload with the endpoint signingSecret.
  signature         String
  // "pending" | "delivered" | "failed"
  status            String
  responseCode      Int?
  responseBody      String?
  attemptCount      Int             @default(0)
  lastAttemptAt     DateTime?
  createdAt         DateTime        @default(now())

  @@index([webhookEndpointId])
  @@index([riskRecordId])
}

model SlackInstallation {
  id               String       @id @default(cuid())
  // @unique enforces one installation per organization.
  organizationId   String       @unique
  organization     Organization @relation(fields: [organizationId], references: [id])
  teamId           String
  teamName         String?
  botUserId        String?
  // Encrypted at rest in production.
  botAccessToken   String
  defaultChannelId String?
  installedById    String?
  installedByName  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model SlackApprovalMessage {
  id             String   @id @default(cuid())
  organizationId String
  riskRecordId   String
  teamId         String
  channelId      String
  // Slack's message timestamp, used to update the card via chat.update.
  messageTs      String
  // "sent" | "decided" | "expired"
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([riskRecordId])
}

model IdempotencyKey {
  // Composite key format: "{orgId}:{endpoint}:{userKey}"
  // Endpoint is included so the same Idempotency-Key from a client maps to
  // different cache entries across different POST routes. This matches the
  // checkIdempotencyKey signature in §3.3 of TRUSTACCEPT_PHASE2_PLAN.md.
  key            String   @id
  organizationId String
  endpoint       String
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
}
