{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "../../src/lib/approval-types.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}
