DATABASE_URL="postgresql://trustaccept:trustaccept@localhost:5432/trustaccept?schema=public"

# TrustAccept for Slack
# https://api.slack.com/apps — create an app, then fill these in.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_REDIRECT_URI=http://localhost:3000/api/integrations/slack/oauth/callback

# Public URL of this TrustAccept instance (used for links in Slack cards).
TRUSTACCEPT_APP_URL=http://localhost:3000

# Shared secret callers must send in `x-trustaccept-secret` when POSTing
# to /api/decisions. Generate with `openssl rand -hex 32`.
TRUSTACCEPT_WEBHOOK_SECRET=
