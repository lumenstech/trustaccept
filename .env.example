# Persistence mode. Default (unset / anything other than "prisma") uses the
# in-memory store at src/server/store.ts. Set to "prisma" to use Postgres.
TRUSTACCEPT_PERSISTENCE=

# Required when TRUSTACCEPT_PERSISTENCE=prisma. The docker-compose.yml
# in this repo brings up a matching instance on localhost:5432.
DATABASE_URL="postgresql://trustaccept:trustaccept@localhost:5432/trustaccept?schema=public"

# Used by the integration suite (tests/integration/*.test.ts) when set.
# Falls back to DATABASE_URL if unset. Point this at a throwaway database
# — the suite truncates rows between cases.
# TEST_DATABASE_URL="postgresql://trustaccept:trustaccept@localhost:5432/trustaccept_test?schema=public"

# Optional. Set to 1 to enable Prisma warn-level logging.
# TRUSTACCEPT_PRISMA_LOG=1

# Required by the middleware to short-circuit demo auth in production.
# Leave unset in dev/test.
# TRUSTACCEPT_DISABLE_DEMO_AUTH=1

# Required in production for stable RS256 signing of decision receipts.
# In dev a 2048-bit ephemeral key is generated per process.
# TRUSTACCEPT_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\n..."
# TRUSTACCEPT_SIGNING_KEY_ID="prod-2026-05"
